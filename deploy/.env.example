# 生产环境变量样例：复制为 deploy/.env 后填写真实值（.env 不要提交到 git）
# cp deploy/.env.example deploy/.env

# --- 数据库 ---
MYSQL_ROOT_PASSWORD=change-me-strong-password
MYSQL_DATABASE=koala
DB_USER=root

# --- Redis ---
REDIS_PASSWORD=change-me-redis-password

# --- 应用 ---
# JWT 密钥，至少 256bit（32+ 字符），务必替换
KOALA_JWT_SECRET=change-me-please-use-a-long-random-secret-min-32-chars
# 超级管理员微信 openid（首次初始化用），可留空
KOALA_SUPER_OPENID=
# 企业微信告警 webhook，可留空
KOALA_ALERT_WEWORK_WEBHOOK=
